<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    android:gravity="center"
    android:orientation="vertical"
    android:background="@color/almostBlack"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <RelativeLayout
        android:background="@drawable/views_container_background"
        android:padding="8.0dip"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="8.0dip">
        <TextView
            android:textSize="25.0sp"
            android:textStyle="bold"
            android:textColor="@color/main_color"
            android:gravity="center"
            android:id="@id/activity_unsupported_minecraft__title_text"
            android:padding="10.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="100.0dip"
            android:text="Unsupported version of Minecraft" />
        <TextView
            android:textSize="15.0sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@id/activity_unsupported_minecraft__error_text"
            android:padding="10.0dip"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/activity_unsupported_minecraft__title_text" />
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="50.0dip"
            android:layout_alignParentBottom="true">
            <TextView
                android:textSize="15.0sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@id/activity_unsupported_minecraft__exit_button"
                android:background="@drawable/button_background"
                android:padding="10.0dip"
                android:layout_width="0.0dip"
                android:layout_height="fill_parent"
                android:text="Exit"
                android:layout_weight="1.0"
                android:onClick="onClick"
                android:layout_marginEnd="2.0dip" />
            <TextView
                android:textSize="15.0sp"
                android:textColor="@color/white"
                android:gravity="center"
                android:id="@id/activity_unsupported_minecraft__play_button"
                android:background="@drawable/button_background"
                android:padding="10.0dip"
                android:layout_width="0.0dip"
                android:layout_height="fill_parent"
                android:text="Play (dangerous!)"
                android:layout_weight="1.0"
                android:onClick="onClick"
                android:layout_marginStart="2.0dip" />
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>