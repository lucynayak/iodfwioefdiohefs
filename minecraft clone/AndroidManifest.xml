            android:exported="false" />
        <activity
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:name="com.facebook.FacebookActivity"
            android:configChanges="keyboard|keyboardHidden|screenLayout" />
        <activity
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:name="com.microsoft.xboxtcui.FbLoginShimActivity"
            android:configChanges="orientation|screenSize" />
        <activity
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:name="com.microsoft.xboxtcui.FbShareShimActivity"
            android:configChanges="orientation|screenSize" />
        <meta-data
            android:name="xperiaplayoptimized_content"
            android:resource="@string/xperiaplayoptimized_content" />
        <meta-data
            android:name="game_display_name"
            android:resource="@string/app_name" />
        <meta-data
            android:name="game_icon"
            android:resource="@drawable/iconx" />
        <meta-data
            android:name="com.facebook.sdk.ApplicationId"
            android:value="@string/facebook_app_id" />
        <meta-data
            android:name="net.hockeyapp.android.appIdentifier"
            android:value="@string/hockeyapp_android_id" />
        <receiver
            android:name="com.appsflyer.SingleInstallBroadcastReceiver"
            android:exported="false">
            <intent-filter>
                <action
                    android:name="com.android.vending.INSTALL_REFERRER" />
            </intent-filter>
        </receiver>
        <uses-library
            android:name="org.apache.http.legacy"
            android:required="false" />
        <uses-library
            android:name="xperiaplaycertified"
            android:required="false" />
        <receiver
            android:name="com.amazon.device.iap.ResponseReceiver"
            android:exported="false">
            <intent-filter>
                <action
                    android:name="com.amazon.inapp.purchasing.NOTIFY"
                    android:permission="com.amazon.inapp.purchasing.Permission.NOTIFY"
                    android:windowSoftInputMode="adjustResize" />
            </intent-filter>
        </receiver>
        <service
            android:name="com.microsoft.onlineid.internal.sso.client.BackupService"
            android:exported="false">
            <intent-filter>
                <action
                    android:name="com.microsoft.onlineid.internal.sso.client.PUSH_BACKUP" />
                <action
                    android:name="com.microsoft.onlineid.internal.sso.client.PUSH_BACKUP_IF_NEEDED" />
                <category
                    android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </service>
        <service
            android:name="com.microsoft.onlineid.internal.MsaService"
            android:exported="false">
            <intent-filter>
                <action
                    android:name="com.microsoft.onlineid.internal.GET_TICKET" />
                <action
                    android:name="com.microsoft.onlineid.internal.UPDATE_PROFILE" />
                <action
                    android:name="com.microsoft.onlineid.internal.SIGN_OUT" />
                <action
                    android:name="com.microsoft.onlineid.internal.SIGN_OUT_ALL_APPS" />
                <category
                    android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </service>
        <service
            android:name="com.microsoft.onlineid.internal.sso.service.MsaSsoService"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action
                    android:name="com.microsoft.msa.action.SSO_SERVICE" />
            </intent-filter>
            <meta-data
                android:name="com.microsoft.msa.service.sso_version"
                android:value="2" />
            <meta-data
                android:name="com.microsoft.msa.service.sdk_version"
                android:value="@string/sdk_version_name" />
        </service>
        <receiver
            android:name="com.google.android.gms.gcm.GcmReceiver"
            android:permission="com.google.android.c2dm.permission.SEND"
            android:exported="true">
            <intent-filter>
                <action
                    android:name="com.google.android.c2dm.intent.RECEIVE" />
                <category
                    android:name="jopa.triggertrash.minecraft" />
            </intent-filter>
        </receiver>
        <service
            android:name="com.mojang.minecraftpe.NotificationListenerService"
            android:exported="false">
            <intent-filter>
                <action
                    android:name="com.google.android.c2dm.intent.RECEIVE" />
            </intent-filter>
        </service>
        <service
            android:name="com.microsoft.xbox.idp.model.gcm.NotificationInstanceIDListenerService"
            android:exported="true">
            <intent-filter>
                <action
                    android:name="com.google.android.gms.iid.InstanceID" />
            </intent-filter>
        </service>
        <service
            android:name="com.microsoft.xbox.idp.model.gcm.RegistrationIntentService"
            android:exported="false" />
